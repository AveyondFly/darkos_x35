# dArkOS base release (upstream tag)
DARKOS_RELEASE="v06072026"

# Upstream RK2023 split archive basename (without .7z.001 suffix)
BASE_IMAGE_BASENAME="dArkOS_RK2023_trixie_06082026"

# GitHub release download URL prefix
DARKOS_DOWNLOAD_BASE="https://github.com/christianhaitian/dArkOS/releases/download/${DARKOS_RELEASE}"

# Mod branding for output filenames
MOD_PREFIX="dArkOS_RK2023_"
MOD_SUFFIX="trixie_06082026"

# RK3566 boot FAT partition number on GPT layout
BOOT_PART=3
ROOTFS_PART=4

# Upstream RK2023 dtb on boot partition (removed during mod)
UPSTREAM_DTB="rk3566-rk2023.dtb"

# Asset paths (relative to repo root)
UBOOT_BIN="RK3566-Specific_uboot.bin"
KERNEL_IMAGE="Image"

# Device variants to build (name:dtb_filename)
MOD_VARIANTS=(
  "X35H:rk3566-powkiddy-x35h.dtb"
  "X35S:rk3566-powkiddy-x35s.dtb"
)

# 7z split volume size (match upstream ~1.9GB parts for GitHub release limits)
SPLIT_SIZE="1950m"
