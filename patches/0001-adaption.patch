diff --git a/drivers/soc/rockchip/rk3566t.c b/drivers/soc/rockchip/rk3566t.c
new file mode 100644
index 000000000..443ac02bc
--- /dev/null
+++ b/drivers/soc/rockchip/rk3566t.c
@@ -0,0 +1,285 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * RK3566T SoC variant detection and OPP limiting.
+ *
+ * Detects the RK3566T variant via the OTP "performance" field, following
+ * the approach used in Radxa's downstream kernel and U-Boot.
+ */
+
+#include <linux/cpu.h>
+#include <linux/device.h>
+#include <linux/module.h>
+#include <linux/notifier.h>
+#include <linux/nvmem-consumer.h>
+#include <linux/of.h>
+#include <linux/platform_device.h>
+#include <linux/pm_opp.h>
+#include <linux/slab.h>
+#include <linux/workqueue.h>
+#include <soc/rockchip/rk3566t.h>
+
+static bool soc_is_rk3566t;
+static bool soc_detected;
+static bool cpu_opps_adjusted;
+static bool gpu_opps_adjusted;
+static bool gpu_notifier_registered;
+static struct delayed_work rk3566t_gpu_work;
+static struct notifier_block rk3566t_gpu_nb;
+static int rk3566t_gpu_retries;
+
+/* RK3566T datasheet caps: keep OPPs at/below these rates available. */
+static const unsigned long rk3566t_cpu_disallowed_hz[] = {
+	1608000000UL,
+	1800000000UL,
+	1992000000UL,
+};
+static const unsigned long rk3566t_cpu_max_hz = 1416000000UL;
+static const unsigned long rk3566t_gpu_disallowed_hz = 800000000UL;
+
+static int rk3566t_register_gpu_notifier(void);
+
+static bool rk3566t_is_gpu_node(struct device_node *np)
+{
+	return of_device_is_compatible(np, "arm,mali-bifrost") ||
+	       of_device_is_compatible(np, "rockchip,rk3568-mali");
+}
+
+static void rk3566t_mark_detected(u8 performance)
+{
+	soc_is_rk3566t = performance & 0x0f;
+	soc_detected = true;
+
+	pr_info("rockchip-cpuinfo: performance=0x%02x, RK3566T=%s\n",
+		performance, soc_is_rk3566t ? "yes" : "no");
+
+	if (soc_is_rk3566t)
+		rk3566t_register_gpu_notifier();
+}
+
+static void rk3566t_detect_once(void)
+{
+	struct device_node *np;
+	struct nvmem_cell *cell;
+	u8 *buf;
+	size_t len;
+	int ret;
+
+	if (soc_detected)
+		return;
+
+	if (!of_machine_is_compatible("rockchip,rk3566")) {
+		soc_detected = true;
+		return;
+	}
+
+	np = of_find_compatible_node(NULL, NULL, "rockchip,cpuinfo");
+	if (!np)
+		return;
+
+	cell = of_nvmem_cell_get(np, "performance");
+	of_node_put(np);
+	if (IS_ERR(cell)) {
+		if (PTR_ERR(cell) == -EPROBE_DEFER)
+			return;
+		soc_detected = true;
+		return;
+	}
+
+	buf = nvmem_cell_read(cell, &len);
+	nvmem_cell_put(cell);
+	if (IS_ERR(buf))
+		return;
+
+	ret = len >= 1 ? buf[0] : 0;
+	kfree(buf);
+
+	rk3566t_mark_detected(ret);
+}
+
+void rockchip_rk3566t_detect_from_cpuinfo(struct device *dev)
+{
+	struct nvmem_cell *cell;
+	u8 *buf;
+	size_t len;
+	int ret;
+
+	if (soc_detected || !dev)
+		return;
+
+	if (!of_machine_is_compatible("rockchip,rk3566"))
+		return;
+
+	cell = nvmem_cell_get(dev, "performance");
+	if (IS_ERR(cell))
+		return;
+
+	buf = nvmem_cell_read(cell, &len);
+	nvmem_cell_put(cell);
+	if (IS_ERR(buf))
+		return;
+
+	ret = len >= 1 ? buf[0] : 0;
+	kfree(buf);
+
+	rk3566t_mark_detected(ret);
+}
+EXPORT_SYMBOL_GPL(rockchip_rk3566t_detect_from_cpuinfo);
+
+bool rockchip_soc_is_rk3566t(void)
+{
+	rk3566t_detect_once();
+	return soc_is_rk3566t;
+}
+EXPORT_SYMBOL_GPL(rockchip_soc_is_rk3566t);
+
+void rockchip_rk3566t_adjust_cpu_opps(struct device *cpu_dev)
+{
+	unsigned long freq;
+	struct dev_pm_opp *opp;
+	int i;
+
+	if (!cpu_dev)
+		return;
+
+	rk3566t_detect_once();
+	if (!soc_is_rk3566t || cpu_opps_adjusted)
+		return;
+
+	/*
+	 * Disable (do not remove) OPPs above the RK3566T limit. Removing them
+	 * while cpufreq/schedutil may already hold OPP references deadlocks
+	 * policy locks (sysfs reads and perfmax hang in D state).
+	 */
+	for (i = 0; i < ARRAY_SIZE(rk3566t_cpu_disallowed_hz); i++)
+		dev_pm_opp_disable(cpu_dev, rk3566t_cpu_disallowed_hz[i]);
+
+	/*
+	 * If U-Boot left the cluster above the new max, pull it down before
+	 * cpufreq builds its table / starts governors.
+	 */
+	freq = rk3566t_cpu_max_hz;
+	opp = dev_pm_opp_find_freq_floor(cpu_dev, &freq);
+	if (!IS_ERR(opp)) {
+		dev_pm_opp_set_rate(cpu_dev, freq);
+		dev_pm_opp_put(opp);
+	}
+
+	cpu_opps_adjusted = true;
+	dev_info(cpu_dev, "RK3566T: CPU OPPs limited to 1416 MHz\n");
+}
+EXPORT_SYMBOL_GPL(rockchip_rk3566t_adjust_cpu_opps);
+
+void rockchip_rk3566t_adjust_gpu_opps(struct device *gpu_dev)
+{
+	if (!gpu_dev || !soc_is_rk3566t)
+		return;
+
+	if (dev_pm_opp_get_opp_count(gpu_dev) <= 0)
+		return;
+
+	/*
+	 * Prefer disable (safe if called more than once). Must run before
+	 * Mali builds its devfreq frequency table, otherwise 800 MHz remains
+	 * listed in available_frequencies even when max_freq is clamped.
+	 */
+	dev_pm_opp_disable(gpu_dev, rk3566t_gpu_disallowed_hz);
+
+	if (!gpu_opps_adjusted)
+		dev_info(gpu_dev, "RK3566T: GPU OPPs limited to 700 MHz\n");
+	gpu_opps_adjusted = true;
+}
+EXPORT_SYMBOL_GPL(rockchip_rk3566t_adjust_gpu_opps);
+
+static void rk3566t_gpu_work_fn(struct work_struct *work)
+{
+	struct device *dev;
+
+	dev = bus_find_device_by_name(&platform_bus_type, NULL, "fde60000.gpu");
+	if (!dev) {
+		struct device_node *np;
+
+		np = of_find_compatible_node(NULL, NULL, "arm,mali-bifrost");
+		if (!np)
+			np = of_find_compatible_node(NULL, NULL, "rockchip,rk3568-mali");
+		if (np) {
+			dev = bus_find_device_by_of_node(&platform_bus_type, np);
+			of_node_put(np);
+		}
+	}
+
+	if (dev) {
+		rockchip_rk3566t_adjust_gpu_opps(dev);
+		put_device(dev);
+	}
+
+	if (!gpu_opps_adjusted && ++rk3566t_gpu_retries < 40)
+		schedule_delayed_work(&rk3566t_gpu_work, msecs_to_jiffies(500));
+}
+
+static int rk3566t_gpu_bus_notifier(struct notifier_block *nb,
+				    unsigned long action, void *data)
+{
+	struct device *dev = data;
+
+	if (action != BUS_NOTIFY_BOUND_DRIVER)
+		return NOTIFY_OK;
+
+	if (!dev->of_node || !rk3566t_is_gpu_node(dev->of_node))
+		return NOTIFY_OK;
+
+	if (gpu_opps_adjusted)
+		return NOTIFY_OK;
+
+	rk3566t_gpu_retries = 0;
+	schedule_delayed_work(&rk3566t_gpu_work, msecs_to_jiffies(100));
+
+	return NOTIFY_OK;
+}
+
+static int rk3566t_match_gpu(struct device *dev, const void *data)
+{
+	return dev->of_node && rk3566t_is_gpu_node(dev->of_node);
+}
+
+static void rk3566t_scan_gpu(void)
+{
+	struct device *dev;
+
+	dev = bus_find_device(&platform_bus_type, NULL, NULL, rk3566t_match_gpu);
+	if (!dev)
+		return;
+
+	if (dev->driver && !gpu_opps_adjusted) {
+		rk3566t_gpu_retries = 0;
+		schedule_delayed_work(&rk3566t_gpu_work, msecs_to_jiffies(100));
+	}
+
+	put_device(dev);
+}
+
+static int rk3566t_register_gpu_notifier(void)
+{
+	int ret;
+
+	if (gpu_notifier_registered || !soc_is_rk3566t)
+		return 0;
+
+	rk3566t_gpu_nb.notifier_call = rk3566t_gpu_bus_notifier;
+	ret = bus_register_notifier(&platform_bus_type, &rk3566t_gpu_nb);
+	if (ret)
+		return ret;
+
+	gpu_notifier_registered = true;
+	rk3566t_scan_gpu();
+	return 0;
+}
+
+static int __init rockchip_rk3566t_init(void)
+{
+	INIT_DELAYED_WORK(&rk3566t_gpu_work, rk3566t_gpu_work_fn);
+	return 0;
+}
+subsys_initcall(rockchip_rk3566t_init);
+
+MODULE_DESCRIPTION("Rockchip RK3566T variant detection");
+MODULE_LICENSE("GPL");
