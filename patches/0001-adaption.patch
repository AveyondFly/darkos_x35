diff --git a/arch/arm64/boot/dts/rockchip/rk3566-powkiddy-x35h.dts b/arch/arm64/boot/dts/rockchip/rk3566-powkiddy-x35h.dts
new file mode 100644
index 000000000..f862294b5
--- /dev/null
+++ b/arch/arm64/boot/dts/rockchip/rk3566-powkiddy-x35h.dts
@@ -0,0 +1,109 @@
+#include "rk3566-powkiddy-x55.dts"
+
+/ {
+	model = "Powkiddy x35h";
+	compatible = "powkiddy,x35h", "rockchip,rk3566";
+
+	/*
+	 * Jack detect on GPIO4_PC6: unplugged=low, plugged=high (verified).
+	 * hp_det keeps bias configured; dArkOS headphone-audio-switch.sh
+	 * watches dmesg "headset status is in/out" from rockchip_headset.
+	 */
+	rk_headset: rk-headset {
+		compatible = "rockchip_headset";
+		headset_gpio = <&gpio4 RK_PC6 GPIO_ACTIVE_HIGH>;
+		pinctrl-names = "default";
+		pinctrl-0 = <&hp_det>;
+	};
+};
+
+&rk817 {
+	battery {
+		design_capacity = <3000>;
+	};
+};
+
+&cru {
+	assigned-clocks = <&pmucru CLK_RTC_32K>, <&cru PLL_GPLL>,
+			  <&pmucru PLL_PPLL>, <&cru PLL_VPLL>;
+	assigned-clock-rates = <32768>, <1200000000>,
+			       <200000000>, <126400000>;
+};
+
+&joypad {
+	abs_x-p-tuning = <0xc8>;
+	abs_x-n-tuning = <0xc8>;
+	abs_y-p-tuning = <0xc8>;
+	abs_y-n-tuning = <0xc8>;
+	abs_rx-p-tuning = <0xc8>;
+	abs_rx-n-tuning = <0xc8>;
+	abs_ry-p-tuning = <0xc8>;
+	abs_ry-n-tuning = <0xc8>;
+	invert-absx;
+	invert-absy;
+	invert-absrx;
+	invert-absry;
+	sw5 {
+		label = "GPIO BTN-B";
+		linux,code = <BTN_SOUTH>;
+	};
+	sw6 {
+		label = "GPIO BTN-A";
+		linux,code = <BTN_EAST>;
+	};
+	sw7 {
+		label = "GPIO BTN-X";
+		linux,code = <BTN_NORTH>;
+	};
+	sw8 {
+		label = "GPIO BTN-Y";
+		linux,code = <BTN_WEST>;
+	};
+	/* Phantom MODE on x35h: line idles low; ACTIVE_LOW made BTN_MODE stuck */
+	sw11 {
+		gpios = <&gpio3 RK_PB7 GPIO_ACTIVE_HIGH>;
+	};
+};
+
+/* dArkOS assumes card0 = rk817 (Playback Path / Master). Probe order alone is
+ * a race vs HDMI; pin ALSA indices so HDMI can stay enabled as card1.
+ */
+&rk817_sound {
+	simple-audio-card,index = <0>;
+};
+
+&hdmi_sound {
+	simple-audio-card,index = <1>;
+};
+
+&panel {
+	compatible = "rocknix,generic-dsi";
+	rotation = <0>;
+	panel_description =
+		"G size=70,52 delays=60,60,60,120,20 format=rgb888 lanes=4 flags=0xa03",
+		"M clock=31600 horizontal=640,113,96,150 vertical=480,20,14,12 default=1",
+		"I seq=b9f11283",
+		"I seq=b1000000da80",
+		"I seq=b2000370",
+		"I seq=b31010fcfc03ff00000000",
+		"I seq=b480",
+		"I seq=b50606",
+		"I seq=b6a9a9",
+		"I seq=b825622003",
+		"I seq=ba338105f90e0e2000000000000000442500900a0000014f01000037",
+		"I seq=bc47",
+		"I seq=bf021100",
+		"I seq=c0737350500000127000",
+		"I seq=c125c0323277e4ffffcccc7777",
+		"I seq=c68200bfff00ff",
+		"I seq=c7b8000a000000",
+		"I seq=c810401e02",
+		"I seq=cc0b",
+		"I seq=e0000a0f293c3f4138080c0f121412131219000a0f293c3f4138080c0f121412131219",
+		"I seq=e307070b0b0b0b00000000ff00c010",
+		"I seq=e9c8100a0000f0811231234f86f0814708000010000000000010000000888808f8f4466002288888888818f8f557711338888800000001000000000000000000",
+		"I seq=ea001a0000000000000000000088f818f88331177558888888f808f88220066448888823000002fe00000000000000000000000000000000000000000000",
+		"I seq=efffff01",
+		"I seq=11 wait=250",
+		"I seq=29 wait=50";
+};
