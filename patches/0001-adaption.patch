+/* SPDX-License-Identifier: GPL-2.0-or-later */
+/*
+ * ROCKNIX singleadc joypad driver
+ *
+ * Copyright (C) 2024 ROCKNIX (https://github.com/ROCKNIX)
+ */
+
+/*----------------------------------------------------------------------------*/
+#include <linux/module.h>
+#include <linux/input-polldev.h>
+#include <linux/platform_device.h>
+#include <linux/iio/consumer.h>
+#include <linux/version.h>
+#if (LINUX_VERSION_CODE < KERNEL_VERSION(6, 3, 0))
+#include <linux/of_gpio.h>
+#else
+#include <linux/of_gpio_legacy.h>
+#endif
+#include <linux/delay.h>
+#include <linux/pwm.h>
+#include "rocknix-joypad.h"
+
+#include <linux/kthread.h>
+#include <linux/tty.h>
+#include <linux/tty_driver.h>
+#include <linux/tty_flip.h>
+#include <linux/fs.h>
+#include <linux/termios.h>
+#include <linux/uaccess.h>
+#include <linux/workqueue.h>
+#include <linux/jiffies.h>
+
+/*----------------------------------------------------------------------------*/
+#define DRV_NAME "rocknix-singleadc-joypad"
+/*----------------------------------------------------------------------------*/
+#define	ADC_MAX_VOLTAGE		1800
+#define	ADC_DATA_TUNING(x, p)	((x * p) / 100)
+#define	ADC_TUNING_DEFAULT	180
+#define	ADC_TUNING_MAX		1000
+#define	CLAMP(x, low, high)  (((x) > (high)) ? (high) : (((x) < (low)) ? (low) : (x)))
+
+/* We add a 5s inactivity timeout for re-opening ttyS1 */
+#define MIYOO_SERIAL_INACTIVITY_TIMEOUT (5 * HZ)
+
+struct bt_adc {
+	/* report value (mV) */
+	int value;
+	/* report type */
+	int report_type;
+	/* input device init value (mV) */
+	int max, min;
+	/* calibrated adc value */
+	int cal;
+	/*  adc scale value */
+	int scale;
+	/* invert report */
+	bool invert;
+	/* amux channel */
+	int amux_ch;
+	/* adc data tuning value([percent), p = positive, n = negative */
+	int tuning_p, tuning_n;
+};
+
+struct analog_mux {
+	/* IIO ADC Channel : amux connect channel */
+	struct iio_channel *iio_ch;
+	/* analog mux select(a,b) gpio */
+	int sel_a_gpio, sel_b_gpio;
+	/* analog mux enable gpio */
+	int en_gpio;
+};
+
+struct bt_gpio {
+	/* GPIO Request label */
+	const char *label;
+	/* GPIO Number */
+	int num;
+	/* report type */
+	int report_type;
+	/* report linux code */
+	int linux_code;
+	/* prev button value */
+	bool old_value;
+	/* button press level */
+	bool active_level;
+};
+
+/* Replicate the calibration and constants from the userland code. */
+#define MIYOO_FRAME_SIZE        6
+#define MIYOO_MAGIC_START       0xFF
+#define MIYOO_MAGIC_END         0xFE
+
+/* For calibrating final ranges to [-32760..32760] */
+#define MIYOO_AXIS_MIN          (-32760)
+#define MIYOO_AXIS_MAX          ( 32760)
+
+/* We'll gather 50 frames for auto-cal */
+#define MIYOO_CALIBRATION_FRAMES    50
+
+/* We'll use a default 10% radial deadzone ratio for example */
+static float miyoo_deadzone_ratio = 0.10f;
+
+struct miyoo_cal {
+	int x_min;
+	int x_max;
+	int x_zero;
+	int y_min;
+	int y_max;
+	int y_zero;
+};
+
+/*
+ * We'll store the "left stick" and "right stick" calibrations
+ * plus live data for the Miyoo serial approach
+ */
+struct miyoo_serial_stick {
+	struct miyoo_cal left_cal;
+	struct miyoo_cal right_cal;
+
+	/* We keep the last parsed values for x,y each stick */
+	int left_x;
+	int left_y;
+	int right_x;
+	int right_y;
+};
+
+/* A forward-declare for our kernel thread function */
+static int miyoo_serial_threadfn(void *data);
+
+/*
+ * We'll define a helper that directly manipulates the tty struct
+ * instead of doing an ioctl() with a kernel pointer.
+ */
+static void set_tty_9600_8N1(struct file *filp)
+{
+	struct tty_file_private *file_priv;
+	struct tty_struct *tty;
+	struct ktermios newt;
+
+	if (!filp || !filp->private_data)
+		return;
+
+	/* filp->private_data is typically a struct tty_file_private if this is a TTY */
+	file_priv = filp->private_data;
+	if (!file_priv || !file_priv->tty)
+		return;
+
+	tty = file_priv->tty;
+
+	/* Copy existing termios and modify it in-kernel. */
+	newt = tty->termios;
+	newt.c_iflag = 0;
+	newt.c_oflag = 0;
+	newt.c_cflag = B9600 | CS8 | CREAD | CLOCAL;
+	newt.c_lflag = 0;
+	memset(newt.c_cc, 0, NCCS);
+	newt.c_cc[VMIN]  = 1;
+	newt.c_cc[VTIME] = 0;
+
+	/*
+	 * This bypasses the userland copy checks, because we are
+	 * operating in kernel space.
+	 */
+	tty_set_termios(tty, &newt);
+}
+
+struct joypad {
+	struct device *dev;
+	int poll_interval;
+
+	/* report enable/disable */
+	bool enable;
+
+	/* analog mux & joystick control */
+	struct analog_mux *amux;
+	/* analog mux max count */
+	int amux_count;
+	/* analog button */
+	struct bt_adc *adcs;
+	bool skip_absr;
+
+	/* report reference point */
+	bool invert_absx;
+	bool invert_absy;
+	bool invert_absrx;
+	bool invert_absry;
+
+	/* report interval (ms) */
+	int bt_gpio_count;
+	struct bt_gpio *gpios;
+
+	/* button auto repeat */
+	int auto_repeat;
+
+	/* report threshold (mV) */
+	int bt_adc_fuzz, bt_adc_flat;
+	/* adc read value scale */
+	int bt_adc_scale;
+	/* joystick deadzone control */
+	int bt_adc_deadzone;
+
+	struct mutex lock;
+
+	/* pwm device for rumble*/
+	struct input_dev *input;
+	struct pwm_device *pwm;
+	struct work_struct play_work;
+	u16 level;
+	u16 boost_weak;
+	u16 boost_strong;
+	bool has_rumble;
+	bool rumble_enabled; /* to turn rumble on/off if a device has it */
+	int rumble_gpio;
+
+
+	/* New property to override logic with Miyoo serial approach */
+	bool use_miyoo_serial;
+	/*
+	 * We store everything for the Miyoo logic:
+	 *   - calibration data
+	 *   - kernel thread
+	 *   - file pointer, etc.
+	 */
+	struct miyoo_serial_stick miyoo;
+	struct task_struct *miyoo_thread;
+	struct file *miyoo_filp;
+
+	/*
+	 * We'll do a delayed work item to do the TTY initialization
+	 * after the driver has finished loading. This ensures we
+	 * don't block the kernel boot.
+	 */
+	struct delayed_work miyoo_init_work;
+
+	/* For detecting inactivity on the Miyoo TTY */
+	unsigned long last_data_jiffies;
+
+};
+
+struct joypad_tuning_attribute {
+	struct device_attribute dev_attr;
+	int report_type;
+	bool positive;
+};
+
+extern struct input_dev * joypad_input_g;
+
+static int pwm_vibrator_start(struct joypad *joypad)
+{
+	struct pwm_state state;
+	int err;
+
+	pwm_get_state(joypad->pwm, &state);
+	pwm_set_relative_duty_cycle(&state, joypad->level, 0xffff);
+	state.enabled = true;
+
+#if (LINUX_VERSION_CODE < KERNEL_VERSION(6, 11, 0))
+	err = pwm_apply_state(joypad->pwm, &state);
+#else
+	err = pwm_apply_might_sleep(joypad->pwm, &state);
+#endif
+	if (err) {
+		 dev_err(joypad->dev, "failed to apply pwm state: %d", err);
+		 return err;
+	}
+
+	return 0;
+}
+
+static int joypad_vibrator_start(struct joypad *joypad)
+{
+	if (gpio_is_valid(joypad->rumble_gpio)) {
+		gpio_set_value(joypad->rumble_gpio, 1);
+		return 0;
+	}
+	return pwm_vibrator_start(joypad);
+}
+
+static void pwm_vibrator_stop(struct joypad *joypad)
+{
+	if (gpio_is_valid(joypad->rumble_gpio)) {
+		gpio_set_value(joypad->rumble_gpio, 0);
+		return;
+	}
+
+	pwm_disable(joypad->pwm);
+}
+
+
+static void joypad_vibrator_stop(struct joypad *joypad)
+{
+	pwm_vibrator_stop(joypad);
+}
+
+static void joypad_vibrator_play_work(struct work_struct *work)
+{
+	struct joypad *joypad = container_of(work,
+					    struct joypad, play_work);
+	mutex_lock(&joypad->lock);
+	if (!joypad->rumble_enabled) {
+		joypad_vibrator_stop(joypad);
+		mutex_unlock(&joypad->lock);
+		return;
+	}
+
+	if (joypad->level)
+		 joypad_vibrator_start(joypad);
+	else
+		 joypad_vibrator_stop(joypad);
+
+	mutex_unlock(&joypad->lock);
+}
+
+/*----------------------------------------------------------------------------*/
+static int joypad_amux_select(struct analog_mux *amux, int channel)
+{
+	/* select mux channel */
+	gpio_set_value_cansleep(amux->en_gpio, 0);
+
+	switch(channel) {
+		case 0:	/* EVENT (ABS_RY) */
+			gpio_set_value_cansleep(amux->sel_a_gpio, 0);
+			gpio_set_value_cansleep(amux->sel_b_gpio, 0);
+			break;
+		case 1:	/* EVENT (ABS_RX) */
+			gpio_set_value_cansleep(amux->sel_a_gpio, 0);
+			gpio_set_value_cansleep(amux->sel_b_gpio, 1);
+			break;
+		case 2:	/* EVENT (ABS_Y) */
+			gpio_set_value_cansleep(amux->sel_a_gpio, 1);
+			gpio_set_value_cansleep(amux->sel_b_gpio, 0);
+			break;
+		case 3:	/* EVENT (ABS_X) */
+			gpio_set_value_cansleep(amux->sel_a_gpio, 1);
+			gpio_set_value_cansleep(amux->sel_b_gpio, 1);
+			break;
+		default:
+			/* amux disanle */
+			gpio_set_value_cansleep(amux->en_gpio, 1);
+			return -1;
+	}
+	/* mux swtiching speed : 35ns(on) / 9ns(off) */
+	usleep_range(10, 20);
+	return 0;
+}
+
+/*----------------------------------------------------------------------------*/
+static int joypad_adc_read(struct analog_mux *amux, struct bt_adc *adc)
+{
+	int value;
+
+
+	if (joypad_amux_select(amux, adc->amux_ch))
+		return 0;
+
+	iio_read_channel_raw(amux->iio_ch, &value);
+
+	value *= adc->scale;
+
+	return value;
+}
+
+static struct bt_adc *joypad_find_adc(struct joypad *joypad, int report_type)
+{
+	int nbtn;
+
+	for (nbtn = 0; nbtn < joypad->amux_count; nbtn++) {
+		struct bt_adc *adc = &joypad->adcs[nbtn];
+
+		if (adc->report_type == report_type)
+			return adc;
+	}
+
+	return NULL;
+}
+
+static int joypad_adc_deadzone_max(struct joypad *joypad)
+{
+	int nbtn;
+	int max = 0;
+
+	for (nbtn = 0; nbtn < joypad->amux_count; nbtn++) {
+		struct bt_adc *adc = &joypad->adcs[nbtn];
+		int axis_max = adc->max;
+
+		if (axis_max <= 0)
+			continue;
+		if (!max || axis_max < max)
+			max = axis_max;
+	}
+
+	return max;
+}
+
+static int *joypad_tuning_value(struct bt_adc *adc, bool logical_positive)
+{
+	bool raw_positive = logical_positive ^ adc->invert;
+
+	return raw_positive ? &adc->tuning_p : &adc->tuning_n;
+}
+
+static ssize_t joypad_show_adc_deadzone(struct device *dev,
+					struct device_attribute *attr,
+					char *buf)
+{
+	struct platform_device *pdev  = to_platform_device(dev);
+	struct joypad *joypad = platform_get_drvdata(pdev);
+	int value;
+
+	mutex_lock(&joypad->lock);
+	value = READ_ONCE(joypad->bt_adc_deadzone);
+	mutex_unlock(&joypad->lock);
+
+	return sprintf(buf, "%d\n", value);
+}
+
+static ssize_t joypad_store_adc_deadzone(struct device *dev,
+					 struct device_attribute *attr,
+					 const char *buf,
+					 size_t count)
+{
+	struct platform_device *pdev  = to_platform_device(dev);
+	struct joypad *joypad = platform_get_drvdata(pdev);
+	int value;
+	int max;
+	int error;
+
+	error = kstrtoint(buf, 0, &value);
+	if (error)
+		return error;
+
+	mutex_lock(&joypad->lock);
+	max = joypad_adc_deadzone_max(joypad);
+	if (value < 0 || !max || value >= max) {
+		mutex_unlock(&joypad->lock);
+		return -EINVAL;
+	}
+
+	WRITE_ONCE(joypad->bt_adc_deadzone, value);
+	mutex_unlock(&joypad->lock);
+
+	return count;
+}
+
+static ssize_t joypad_show_tuning(struct device *dev,
+				  struct device_attribute *attr,
+				  char *buf)
+{
+	struct platform_device *pdev  = to_platform_device(dev);
+	struct joypad *joypad = platform_get_drvdata(pdev);
+	struct joypad_tuning_attribute *tuning_attr =
+		container_of(attr, struct joypad_tuning_attribute, dev_attr);
+	struct bt_adc *adc;
+	int value;
+
+	mutex_lock(&joypad->lock);
+	adc = joypad_find_adc(joypad, tuning_attr->report_type);
+	if (!adc) {
+		mutex_unlock(&joypad->lock);
+		return -ENODEV;
+	}
+
+	value = READ_ONCE(*joypad_tuning_value(adc, tuning_attr->positive));
+	mutex_unlock(&joypad->lock);
+
+	return sprintf(buf, "%d\n", value);
+}
+
+static ssize_t joypad_store_tuning(struct device *dev,
+				   struct device_attribute *attr,
+				   const char *buf,
+				   size_t count)
+{
+	struct platform_device *pdev  = to_platform_device(dev);
+	struct joypad *joypad = platform_get_drvdata(pdev);
+	struct joypad_tuning_attribute *tuning_attr =
+		container_of(attr, struct joypad_tuning_attribute, dev_attr);
+	struct bt_adc *adc;
+	int value;
+	int error;
+
+	error = kstrtoint(buf, 0, &value);
+	if (error)
+		return error;
+	if (value < 0 || value > ADC_TUNING_MAX)
+		return -EINVAL;
+
+	mutex_lock(&joypad->lock);
+	adc = joypad_find_adc(joypad, tuning_attr->report_type);
+	if (!adc) {
+		mutex_unlock(&joypad->lock);
+		return -ENODEV;
+	}
+
+	WRITE_ONCE(*joypad_tuning_value(adc, tuning_attr->positive), value);
+	mutex_unlock(&joypad->lock);
+
+	return count;
+}
+
+#define JOYPAD_TUNING_ATTR(_name, _report_type, _positive)		\
+	static struct joypad_tuning_attribute joypad_attr_##_name = {	\
+		.dev_attr = __ATTR(_name, S_IWUSR | S_IRUGO,		\
+				   joypad_show_tuning,			\
+				   joypad_store_tuning),		\
+		.report_type = _report_type,				\
+		.positive = _positive,				\
+	}
+
+static DEVICE_ATTR(adc_deadzone, S_IWUSR | S_IRUGO,
+		   joypad_show_adc_deadzone,
+		   joypad_store_adc_deadzone);
+JOYPAD_TUNING_ATTR(abs_x_p_tuning, ABS_X, true);
+JOYPAD_TUNING_ATTR(abs_x_n_tuning, ABS_X, false);
+JOYPAD_TUNING_ATTR(abs_y_p_tuning, ABS_Y, true);
+JOYPAD_TUNING_ATTR(abs_y_n_tuning, ABS_Y, false);
+JOYPAD_TUNING_ATTR(abs_rx_p_tuning, ABS_RX, true);
+JOYPAD_TUNING_ATTR(abs_rx_n_tuning, ABS_RX, false);
+JOYPAD_TUNING_ATTR(abs_ry_p_tuning, ABS_RY, true);
+JOYPAD_TUNING_ATTR(abs_ry_n_tuning, ABS_RY, false);
+
+static umode_t joypad_adc_attr_is_visible(struct kobject *kobj,
+					  struct attribute *attr,
+					  int n)
+{
+	struct device *dev = kobj_to_dev(kobj);
+	struct platform_device *pdev = to_platform_device(dev);
+	struct joypad *joypad = platform_get_drvdata(pdev);
+	struct device_attribute *dev_attr;
+	struct joypad_tuning_attribute *tuning_attr;
+
+	if (attr == &dev_attr_adc_deadzone.attr)
+		return attr->mode;
+
+	dev_attr = container_of(attr, struct device_attribute, attr);
+	tuning_attr = container_of(dev_attr, struct joypad_tuning_attribute,
+				   dev_attr);
+
+	if (!joypad || !joypad_find_adc(joypad, tuning_attr->report_type))
+		return 0;
+
+	return attr->mode;
+}
+
+static struct attribute *joypad_adc_attrs[] = {
+	&dev_attr_adc_deadzone.attr,
+	&joypad_attr_abs_x_p_tuning.dev_attr.attr,
+	&joypad_attr_abs_x_n_tuning.dev_attr.attr,
+	&joypad_attr_abs_y_p_tuning.dev_attr.attr,
+	&joypad_attr_abs_y_n_tuning.dev_attr.attr,
+	&joypad_attr_abs_rx_p_tuning.dev_attr.attr,
+	&joypad_attr_abs_rx_n_tuning.dev_attr.attr,
+	&joypad_attr_abs_ry_p_tuning.dev_attr.attr,
+	&joypad_attr_abs_ry_n_tuning.dev_attr.attr,
+	NULL,
+};
+
+static struct attribute_group joypad_adc_attr_group = {
+	.attrs = joypad_adc_attrs,
+	.is_visible = joypad_adc_attr_is_visible,
+};
